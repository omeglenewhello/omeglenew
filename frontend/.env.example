# Backend WebSocket server URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Your site's public URL (used for SEO/OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Google AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Leave empty to disable ads
NEXT_PUBLIC_ADSENSE_ID=

# Site name (shown in title, OG, etc.)
NEXT_PUBLIC_SITE_NAME=StrangerChat
